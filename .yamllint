# Relaxed yamllint for HA package YAML (long Jinja template lines are expected).
extends: relaxed

rules:
  line-length: disable
  comments:
    min-spaces-from-content: 1
  comments-indentation: disable
  document-start: disable
  truthy:
    allowed-values: ["true", "false", "on", "off"]
    check-keys: false
  braces:
    max-spaces-inside: 1
  empty-lines:
    max: 2
